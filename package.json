{
  "name": "@appswave/rq-codegen",
  "version": "0.1.0",
  "description": "Config-driven code generator for React + TypeScript projects with React Query, handlers, DTOs, and more",
  "type": "module",
  "bin": {
    "rq-codegen": "./dist/bin/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "typescript",
    "code-generator",
    "cli",
    "react-query",
    "plop",
    "scaffolding",
    "handler",
    "dto"
  ],
  "license": "MIT",
  "author": "Appswave",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "handlebars": "^4.7.8",
    "inquirer": "^9.3.7",
    "ora": "^8.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  }
}
